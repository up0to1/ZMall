      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="生成测试摘要" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.io.*;

String runDir = props.get(&quot;RUN_DIR&quot;);
String ts = props.get(&quot;TEST_TS&quot;);
if (runDir == null || ts == null) {
    log.info(&quot;==== tearDown: RUN_DIR null, skip&quot;);
    return;
}

String summaryPath = runDir + &quot;/summary.txt&quot;;
String testName = props.get(&quot;TEST_NAME&quot;);
if (testName == null) testName = &quot;itemOversell&quot;;

String csvPrefix;
int codeFieldIndex;
boolean isIterFormat;
if (testName.equals(&quot;itemOneUser&quot;)) {
    csvPrefix = &quot;itemOneUser_detail_&quot;; isIterFormat = true; codeFieldIndex = 2;
} else if (testName.equals(&quot;itemMultiUser&quot;)) {
    csvPrefix = &quot;itemMultiUser_detail_&quot;; isIterFormat = true; codeFieldIndex = 2;
} else if (testName.equals(&quot;couponOneUser&quot;)) {
    csvPrefix = &quot;couponOneUser_detail_&quot;; isIterFormat = true; codeFieldIndex = 2;
} else if (testName.equals(&quot;couponOversell&quot;)) {
    csvPrefix = &quot;couponOversell_detail_&quot;; isIterFormat = false; codeFieldIndex = 1;
} else {
    csvPrefix = &quot;itemOversell_detail_&quot;; isIterFormat = false; codeFieldIndex = 1;
}

int code0 = 0;
int code1 = 0;
int code2 = 0;
int codeOther = 0;
int total = 0;

File csvFile = new File(runDir + &quot;/&quot; + csvPrefix + ts + &quot;.csv&quot;);
if (!csvFile.exists()) {
    log.info(&quot;==== tearDown: CSV not found: &quot; + csvFile);
} else {
    BufferedReader br = new BufferedReader(new FileReader(csvFile));
    String line;
    while ((line = br.readLine()) != null) {
        if (line.startsWith(&quot;username,&quot;)) continue;
        total++;
        String[] parts = line.split(&quot;,&quot;, isIterFormat ? 4 : 3);
        String codeField = parts.length &gt; codeFieldIndex ? parts[codeFieldIndex].trim() : &quot;&quot;;
        if (codeField.equals(&quot;0&quot;)) code0++;
        else if (codeField.equals(&quot;1&quot;)) code1++;
        else if (codeField.equals(&quot;2&quot;)) code2++;
        else codeOther++;
    }
    br.close();
}

Long totalReq = (Long) props.get(&quot;PERF_TOTAL_REQ&quot;);
Long successCount = (Long) props.get(&quot;PERF_SUCCESS&quot;);
Long perfError = (Long) props.get(&quot;PERF_ERROR&quot;);
Long totalBytes = (Long) props.get(&quot;PERF_TOTAL_BYTES&quot;);
Long totalSent = (Long) props.get(&quot;PERF_TOTAL_SENT&quot;);
Long totalTime = (Long) props.get(&quot;PERF_TOTAL_TIME&quot;);
Long minTime = (Long) props.get(&quot;PERF_MIN_TIME&quot;);
Long maxTime = (Long) props.get(&quot;PERF_MAX_TIME&quot;);
Long startTs = (Long) props.get(&quot;PERF_START_TS&quot;);
Long endTs = (Long) props.get(&quot;PERF_END_TS&quot;);

if (totalReq == null) totalReq = 0L;
if (successCount == null) successCount = 0L;
if (perfError == null) perfError = 0L;
if (totalBytes == null) totalBytes = 0L;
if (totalSent == null) totalSent = 0L;
if (totalTime == null) totalTime = 0L;

double errorRate = totalReq &gt; 0 ? (perfError * 100.0 / totalReq) : 0;
double avgTime = totalReq &gt; 0 ? (totalTime * 1.0 / totalReq) : 0;
long durationMs = (endTs != null &amp;&amp; startTs != null) ? (endTs - startTs) : 0;
double durationSec = durationMs / 1000.0;
double qps = durationSec &gt; 0 ? (totalReq / durationSec) : 0;
double recvKBps = durationSec &gt; 0 ? (totalBytes / 1024.0 / durationSec) : 0;
double sentKBps = durationSec &gt; 0 ? (totalSent / 1024.0 / durationSec) : 0;

PrintWriter pw = new PrintWriter(new FileWriter(summaryPath));
pw.println(&quot;========================================&quot;);
pw.println(&quot;ZMall 测试结果摘要&quot;);
pw.println(&quot;========================================&quot;);
pw.println(&quot;测试时间: &quot; + ts);
pw.println(&quot;测试类型: &quot; + props.get(&quot;TEST_NAME&quot;));
pw.println(&quot;----------------------------------------&quot;);
pw.println(&quot;一、系统性能指标&quot;);
pw.println(&quot;----------------------------------------&quot;);
pw.println(&quot;总请求数: &quot; + totalReq);
pw.println(&quot;成功请求数: &quot; + successCount);
pw.println(&quot;失败请求数: &quot; + perfError);
pw.println(&quot;异常率: &quot; + String.format(&quot;%.2f%%&quot;, errorRate));
pw.println(&quot;测试持续时间: &quot; + String.format(&quot;%.2f&quot;, durationSec) + &quot; 秒&quot;);
pw.println(&quot;吞吐量(QPS): &quot; + String.format(&quot;%.2f&quot;, qps) + &quot; req/s&quot;);
pw.println(&quot;平均响应时间: &quot; + String.format(&quot;%.2f&quot;, avgTime) + &quot; ms&quot;);
pw.println(&quot;最小响应时间: &quot; + (minTime != null ? minTime : 0) + &quot; ms&quot;);
pw.println(&quot;最大响应时间: &quot; + (maxTime != null ? maxTime : 0) + &quot; ms&quot;);
pw.println(&quot;接收数据速率: &quot; + String.format(&quot;%.2f&quot;, recvKBps) + &quot; KB/sec&quot;);
pw.println(&quot;发送数据速率: &quot; + String.format(&quot;%.2f&quot;, sentKBps) + &quot; KB/sec&quot;);
double avgRecvBytes = totalReq &gt; 0 ? (totalBytes * 1.0 / totalReq) : 0;
double avgSentBytes = totalReq &gt; 0 ? (totalSent * 1.0 / totalReq) : 0;
pw.println(&quot;平均接收字节数: &quot; + String.format(&quot;%.2f&quot;, avgRecvBytes) + &quot; bytes&quot;);
pw.println(&quot;平均发送字节数: &quot; + String.format(&quot;%.2f&quot;, avgSentBytes) + &quot; bytes&quot;);
pw.println(&quot;----------------------------------------&quot;);
pw.println(&quot;二、业务结果分布 (CSV记录)&quot;);
pw.println(&quot;----------------------------------------&quot;);
pw.println(&quot;总请求(CSV记录): &quot; + total);
if (isIterFormat) {
    pw.println(&quot;  code=0 (秒杀成功): &quot; + code0);
    pw.println(&quot;  code=1 (库存不足): &quot; + code1);
    pw.println(&quot;  code=2 (重复下单): &quot; + code2);
    pw.println(&quot;  其他: &quot; + codeOther);
} else {
    pw.println(&quot;打到后端的请求数: &quot; + (code0 + code1 + code2));
    pw.println(&quot;  code=0 (秒杀成功): &quot; + code0);
    pw.println(&quot;  code=1 (库存不足): &quot; + code1);
    pw.println(&quot;  code=2 (重复下单): &quot; + code2);
    pw.println(&quot;被网关/网络拒绝的请求数: &quot; + codeOther);
}
pw.println(&quot;----------------------------------------&quot;);
if (testName.equals(&quot;itemOneUser&quot;) || testName.equals(&quot;couponOneUser&quot;)) {
    pw.println(&quot;三、验证项 (一人一单)&quot;);
    pw.println(&quot;----------------------------------------&quot;);
    pw.println(&quot;  1. code=0的数量应=1 (同一用户首次请求成功)&quot;);
    pw.println(&quot;  2. code=2的数量应=总请求-1 (后续重复下单被拦截)&quot;);
    pw.println(&quot;  3. 一人一单防护生效 (Redis Set 限购)&quot;);
} else if (testName.equals(&quot;itemMultiUser&quot;)) {
    pw.println(&quot;三、验证项 (一人多单)&quot;);
    pw.println(&quot;----------------------------------------&quot;);
    pw.println(&quot;  1. code=0的数量应=maxPerUser (同一用户多次下单成功)&quot;);
    pw.println(&quot;  2. code=2的数量应=总请求-maxPerUser (超过限购被拦截)&quot;);
    pw.println(&quot;  3. 一人多单验证 (商品 maxPerUser&gt;1)&quot;);
} else if (testName.equals(&quot;couponOversell&quot;)) {
    pw.println(&quot;三、验证项 (优惠券超卖)&quot;);
    pw.println(&quot;----------------------------------------&quot;);
    pw.println(&quot;  1. code=0的数量应=优惠券库存数 (无超卖)&quot;);
    pw.println(&quot;  2. code=1表示库存防护生效&quot;);
    pw.println(&quot;  3. 被拒绝请求数 = 总请求 - 打到后端请求&quot;);
} else {
    pw.println(&quot;三、验证项 (超卖测试)&quot;);
    pw.println(&quot;----------------------------------------&quot;);
    pw.println(&quot;  1. code=0的数量应=秒杀库存数 (无超卖)&quot;);
    pw.println(&quot;  2. code=1表示库存防护生效&quot;);
    pw.println(&quot;  3. code=2表示一人一单防护生效&quot;);
    pw.println(&quot;  4. 被拒绝请求数 = 总请求 - 打到后端请求&quot;);
}
pw.println(&quot;========================================&quot;);
pw.close();

log.info(&quot;==== tearDown: summary written to &quot; + summaryPath);
log.info(&quot;==== tearDown: total=&quot; + total + &quot; code0=&quot; + code0 + &quot; code1=&quot; + code1 + &quot; code2=&quot; + code2);
log.info(&quot;==== tearDown: summary written to &quot; + summaryPath);
</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
