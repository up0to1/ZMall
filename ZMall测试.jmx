          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="设置coupon_oneuser测试目录" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="script">String testName = &quot;couponOneUser&quot;;
String base = vars.get(&quot;TEST_BASE&quot;);
String date = vars.get(&quot;TEST_DATE&quot;);
String ts = vars.get(&quot;TEST_TS&quot;);
String runDir = base + &quot;/&quot; + date + &quot;_&quot; + testName + &quot;/&quot; + ts;
props.put(&quot;RUN_DIR&quot;, runDir);
props.put(&quot;TEST_NAME&quot;, testName);
vars.put(&quot;RUN_DIR&quot;, runDir);
vars.put(&quot;TEST_NAME&quot;, testName);
String savedToken = props.get(&quot;COUPON_ONEUSER_TOKEN&quot;);
if (savedToken == null) {
    props.put(&quot;COUPON_ONEUSER_TOKEN&quot;, vars.get(&quot;token&quot;));
    props.put(&quot;COUPON_ONEUSER_USERNAME&quot;, vars.get(&quot;username&quot;));
    props.remove(&quot;PERF_TOTAL_REQ&quot;);
    props.remove(&quot;PERF_SUCCESS&quot;);
    props.remove(&quot;PERF_ERROR&quot;);
    props.remove(&quot;PERF_TOTAL_BYTES&quot;);
    props.remove(&quot;PERF_TOTAL_SENT&quot;);
    props.remove(&quot;PERF_TOTAL_TIME&quot;);
    props.remove(&quot;PERF_MIN_TIME&quot;);
    props.remove(&quot;PERF_MAX_TIME&quot;);
    props.remove(&quot;PERF_START_TS&quot;);
    props.remove(&quot;PERF_END_TS&quot;);
    File f = new File(runDir);
    if (!f.exists()) f.mkdirs();
    log.info(&quot;==== couponOneUser first RUN_DIR=&quot; + runDir + &quot; user=&quot; + vars.get(&quot;username&quot;));
} else {
    vars.put(&quot;token&quot;, savedToken);
    vars.put(&quot;username&quot;, props.get(&quot;COUPON_ONEUSER_USERNAME&quot;));
    log.info(&quot;==== couponOneUser reuse user=&quot; + vars.get(&quot;username&quot;));
}</stringProp>
          </JSR223PreProcessor>
