          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="设置multiuser测试目录" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="script">String testName = &quot;itemMultiUser&quot;;
String base = vars.get(&quot;TEST_BASE&quot;);
String date = vars.get(&quot;TEST_DATE&quot;);
String ts = vars.get(&quot;TEST_TS&quot;);
String runDir = base + &quot;/&quot; + date + &quot;_&quot; + testName + &quot;/&quot; + ts;
props.put(&quot;RUN_DIR&quot;, runDir);
props.put(&quot;TEST_NAME&quot;, testName);
vars.put(&quot;RUN_DIR&quot;, runDir);
vars.put(&quot;TEST_NAME&quot;, testName);
String savedToken = vars.get(&quot;MULTIUSER_TOKEN&quot;);
if (savedToken == null) {
    vars.put(&quot;MULTIUSER_TOKEN&quot;, vars.get(&quot;token&quot;));
    vars.put(&quot;MULTIUSER_USERNAME&quot;, vars.get(&quot;username&quot;));
    if (props.get(&quot;MULTIUSER_PERF_RESET&quot;) == null) {
        props.put(&quot;MULTIUSER_PERF_RESET&quot;, &quot;1&quot;);
        props.remove(&quot;PERF_TOTAL_REQ&quot;);
        props.remove(&quot;PERF_SUCCESS&quot;);
        props.remove(&quot;PERF_ERROR&quot;);
        props.remove(&quot;PERF_TOTAL_BYTES&quot;);
        props.remove(&quot;PERF_TOTAL_SENT&quot;);
        props.remove(&quot;PERF_TOTAL_TIME&quot;);
        props.remove(&quot;PERF_MIN_TIME&quot;);
        props.remove(&quot;PERF_MAX_TIME&quot;);
        props.remove(&quot;PERF_START_TS&quot;);
        props.remove(&quot;PERF_END_TS&quot;);
        File f = new File(runDir);
        if (!f.exists()) f.mkdirs();
    }
    log.info(&quot;==== itemMultiUser thread first user=&quot; + vars.get(&quot;username&quot;));
} else {
    vars.put(&quot;token&quot;, savedToken);
    vars.put(&quot;username&quot;, vars.get(&quot;MULTIUSER_USERNAME&quot;));
    log.info(&quot;==== itemMultiUser reuse user=&quot; + vars.get(&quot;username&quot;));
}</stringProp>
