          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 预处理程序" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="script">// 重置性能统计
props.remove(&quot;PERF_TOTAL_REQ&quot;);
props.remove(&quot;PERF_SUCCESS&quot;);
props.remove(&quot;PERF_ERROR&quot;);
props.remove(&quot;PERF_TOTAL_BYTES&quot;);
