props.remove(&quot;PERF_TOTAL_TIME&quot;);
props.remove(&quot;PERF_MIN_TIME&quot;);
props.remove(&quot;PERF_MAX_TIME&quot;);
props.remove(&quot;PERF_START_TS&quot;);
props.remove(&quot;PERF_END_TS&quot;);
// 设置全局变量供 tearDown 使用
props.put(&quot;TEST_TS&quot;, vars.get(&quot;TEST_TS&quot;));
props.put(&quot;TEST_DATE&quot;, vars.get(&quot;TEST_DATE&quot;));
props.put(&quot;TEST_BASE&quot;, vars.get(&quot;TEST_BASE&quot;));
log.info(&quot;==== setUp: PERF stats reset, TEST_TS=&quot; + props.get(&quot;TEST_TS&quot;));</stringProp>
          </JSR223PreProcessor>
