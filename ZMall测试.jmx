          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP信息头管理器-优惠券超卖" enabled="true">
            <collectionProp name="HeaderManager.headers">
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">authorization</stringProp>
                <stringProp name="Header.value">${token}</stringProp>
              </elementProp>
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Content-Type</stringProp>
                <stringProp name="Header.value">application/json</stringProp>
              </elementProp>
            </collectionProp>
          </HeaderManager>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="结果保存-优惠券超卖" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="script">import java.io.File;
import java.io.FileWriter;
import java.io.PrintWriter;

String res = prev.getResponseDataAsString();
String code = &quot;parse_fail&quot;;
int codeStart = res.indexOf(&quot;\&quot;code\&quot;:&quot;);
if (codeStart &gt;= 0) {
    int s = res.indexOf(&quot;:&quot;, codeStart) + 1;
    int e = res.indexOf(&quot;,&quot;, s);
    if (e &lt; 0) e = res.indexOf(&quot;}&quot;, s);
    code = res.substring(s, e).trim();
}

String user = vars.get(&quot;username&quot;);
String runDir = props.get(&quot;RUN_DIR&quot;);
String ts = props.get(&quot;TEST_TS&quot;);
if (runDir == null) runDir = vars.get(&quot;TEST_BASE&quot;) + &quot;/&quot; + vars.get(&quot;TEST_DATE&quot;) + &quot;_&quot; + vars.get(&quot;TEST_NAME&quot;) + &quot;/&quot; + ts;
new File(runDir).mkdirs();
String csvPath = runDir + &quot;/couponOversell_detail_&quot; + ts + &quot;.csv&quot;;

synchronized (csvPath.intern()) {
    File f = new File(csvPath);
    boolean needHeader = !f.exists();
    PrintWriter pw = null;
    try {
        pw = new PrintWriter(new FileWriter(csvPath, true));
        if (needHeader) {
            pw.println(&quot;username,code,response,elapsed,connect,latency,bytes,sentBytes,success&quot;);
        }
        String safeRes = res.replace(&quot;\n&quot;, &quot;&quot;).replace(&quot;\r&quot;, &quot;&quot;);
        long elapsed = prev.getTime();
        long connect = prev.getConnectTime();
        long latency = prev.getLatency();
        long bytes = prev.getBytesAsLong();
        int sent = prev.getSentBytes();
        boolean succ = prev.isSuccessful();
        pw.println(user + &quot;,&quot; + code + &quot;,&quot; + safeRes + &quot;,&quot; + elapsed + &quot;,&quot; + connect + &quot;,&quot; + latency + &quot;,&quot; + bytes + &quot;,&quot; + sent + &quot;,&quot; + succ);
    } finally {
        if (pw != null) pw.close();
    }
}
// 全局累加性能统计
synchronized (&quot;PERF_STATS&quot;) {
    Long totalReq = (Long) props.get(&quot;PERF_TOTAL_REQ&quot;);
    if (totalReq == null) totalReq = 0L;
    props.put(&quot;PERF_TOTAL_REQ&quot;, totalReq + 1);
    if (prev.isSuccessful()) {
        Long succ = (Long) props.get(&quot;PERF_SUCCESS&quot;);
        if (succ == null) succ = 0L;
        props.put(&quot;PERF_SUCCESS&quot;, succ + 1);
    } else {
        Long err = (Long) props.get(&quot;PERF_ERROR&quot;);
        if (err == null) err = 0L;
        props.put(&quot;PERF_ERROR&quot;, err + 1);
    }
    Long totalBytes = (Long) props.get(&quot;PERF_TOTAL_BYTES&quot;);
    if (totalBytes == null) totalBytes = 0L;
    props.put(&quot;PERF_TOTAL_BYTES&quot;, totalBytes + prev.getBytesAsLong());
    Long totalSent = (Long) props.get(&quot;PERF_TOTAL_SENT&quot;);
    if (totalSent == null) totalSent = 0L;
    props.put(&quot;PERF_TOTAL_SENT&quot;, totalSent + prev.getSentBytes());
    Long totalTime = (Long) props.get(&quot;PERF_TOTAL_TIME&quot;);
    if (totalTime == null) totalTime = 0L;
    props.put(&quot;PERF_TOTAL_TIME&quot;, totalTime + prev.getTime());
    Long minTime = (Long) props.get(&quot;PERF_MIN_TIME&quot;);
    Long maxTime = (Long) props.get(&quot;PERF_MAX_TIME&quot;);
    if (minTime == null || prev.getTime() &lt; minTime) props.put(&quot;PERF_MIN_TIME&quot;, (long) prev.getTime());
    if (maxTime == null || prev.getTime() &gt; maxTime) props.put(&quot;PERF_MAX_TIME&quot;, (long) prev.getTime());
    long sampleStart = prev.getStartTime();
    long sampleEnd = prev.getEndTime();
    Long startTs = (Long) props.get(&quot;PERF_START_TS&quot;);
    if (startTs == null || sampleStart &lt; startTs) props.put(&quot;PERF_START_TS&quot;, sampleStart);
    Long endTs = (Long) props.get(&quot;PERF_END_TS&quot;);
    if (endTs == null || sampleEnd &gt; endTs) props.put(&quot;PERF_END_TS&quot;, sampleEnd);
}</stringProp>
          </JSR223PostProcessor>
